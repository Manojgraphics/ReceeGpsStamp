rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Roles ──────────────────────────────────────────────────────────────
    // ADMINS are hard-coded here (owners — cannot be removed from the UI, for safety).
    // MANAGERS are dynamic: stored in /config/access and editable by admins in the dashboard.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in [
          'info4mediaearth@gmail.com'   // hard-coded owner (root) — never removable
        ] ||
        (exists(/databases/$(database)/documents/config/access) &&
         request.auth.token.email in get(/databases/$(database)/documents/config/access).data.get('admins', []))
      );
    }
    function managerEmails() {
      return get(/databases/$(database)/documents/config/access).data.managers;
    }
    function isManager() {
      return request.auth != null && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/config/access) &&
         request.auth.token.email in managerEmails())
      );
    }

    // Access-control doc — any signed-in user may READ it (just an email list);
    // only ADMINS may change who the managers are.
    // Config docs (access list, targets, …) — any signed-in user reads; only admins write.
    match /config/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // Assignments — admins/managers assign shops to a surveyor; the surveyor's app reads its own.
    match /assignments/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isManager());
      allow write: if isManager();
    }

    // Audit log — managers/admins log actions; managers can read.
    match /audit/{id} {
      allow read:   if isManager();
      allow create: if isManager();
    }

    // Expense approvals — managers approve/reject; the surveyor reads their own status.
    match /approvals/{uid} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isManager());
      allow write: if isManager();
    }

    // Vehicle registry — managers add/assign/service vehicles (the assigned vehicle is also
    // stamped into the surveyor's own assignments doc, which the app already reads).
    match /vehicles/{id} {
      allow read, write: if isManager();
    }

    // Shared company fleet — any signed-in employee may add/update a vehicle or log fuel/service,
    // but the doc must look like a vehicle (has `number`); only managers may DELETE (blocks a
    // team-wide wipe). On a merge-update `request.resource.data` is the post-merge doc, so the
    // existing `number` keeps fuel/service log updates allowed.
    match /fleet/{id} {
      allow read:           if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.number is string;
      allow delete:         if isManager();
    }

    // Shared project catalog (companies + distributors w/ creatives & media) — any signed-in
    // employee may upsert, but the JSON must be non-empty ("" =0 / "[]" =2 chars → rejected, so
    // a client can't blank the team's catalog); only managers may DELETE.
    match /catalog/{doc} {
      allow read:           if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.json is string
                             && request.resource.data.json.size() > 2;
      allow delete:         if isManager();
    }

    // Installation/approval workflow — admins/managers approve recce'd shops, track install
    // status + quality, export. Web-only (admin/manager).
    match /installations/{id} {
      allow read, write: if isManager();
    }

    // Each surveyor owns their backup; managers (and admins) can read everyone's.
    match /users/{uid}/backup/{doc} {
      allow read:  if request.auth != null && (request.auth.uid == uid || isManager());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // collectionGroup("backup") — one query pulls every surveyor for the dashboard.
    match /{path=**}/backup/{doc} {
      allow read: if isManager();
    }
  }
}
