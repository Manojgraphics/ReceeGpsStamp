rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // NOTE: Storage rules cannot read Firestore, so the dynamic manager list can't be
    // checked here. Read is allowed to any SIGNED-IN user — which is safe because a
    // photo's path is only discoverable from the recce data in Firestore, and that data
    // is gated to the owner + managers. A surveyor can therefore only reach their own
    // photos (they can't read other surveyors' recce data to learn the paths). Writes
    // stay locked to the owning surveyor.
    match /users/{uid}/files/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
